# ==========================================
# VPS MANAGER - GLOBAL CONFIGURATION TEMPLATE
# Nhớ rename file này thành `.env` trước khi chạy script.
# ==========================================

# 1. HỆ THỐNG
APP_USER="www-data"                 # User chủ sở hữu chung cho tất cả Application Code Base

# 2. BẢO MẬT & FIREWALL (UFW)
# Các cổng sẽ ưu tiên mở trên Firewall (cách nhau bằng khoảng trắng)
UFW_ALLOW_PORTS="22 80 443"

# 3. DATABASE (MYSQL) - TÀI KHOẢN GỐC ROOT (Dùng tạo DB sau này)
DB_ROOT_PASSWORD="root_password_secure"

# 4. BACKUP (MYSQL)
KEEP_BACKUP_DAYS=7
BACKUP_DIR="/var/backups/mysql"

# 5. GIÁM SÁT HỆ THỐNG (TELEGRAM ALERT)
TELEGRAM_BOT_TOKEN="your_bot_token"
TELEGRAM_CHAT_ID="your_chat_id"
ALERT_CPU_THRESHOLD=85              # % Ngưỡng cảnh báo CPU
ALERT_RAM_THRESHOLD=85              # % Ngưỡng cảnh báo RAM
ALERT_DISK_THRESHOLD=90             # % Ngưỡng cảnh báo Full Ổ cứng
# 6. PHIÊN BẢN PHẦN MỀM MẶC ĐỊNH
PHP_VERSION="8.3"                   # Phiên bản PHP mặc định khi cài đặt hệ thống
NODE_VERSION="20"                   # Phiên bản Node.js (LTS)
