# ==========================================
# VPS MANAGER - SITE CONFIGURATION TEMPLATE
# Lưu tại: sites/.env.<domain>
# ==========================================

# 1. THÔNG TIN ỨNG DỤNG ĐỘC LẬP
APP_DOMAIN="example.com"
PHP_VERSION="8.3"                   # Phiên bản PHP (ví dụ: 8.2, 8.3, 8.4)
SUPERVISOR_REVERB_PORT=8080         # Port của Laravel Reverb nếu chạy riêng

# 2. DATABASE (MYSQL) - SITE SPECIFIC
DB_NAME="laravel_db"
DB_USER="laravel_user"
DB_PASSWORD="your_strong_password"

# 3. GIÁM SÁT LARAVEL CHECK URL (Tính năng Monitor Ping HTTP Mặc Định 200 OK)
# Cấu hình Nâng cao (Tùy chọn)
USE_JWT="false"
USE_SSR="false"
SSR_PORT="13714"
SSH_KEY_PATH=""
HEALTH_CHECK_URL="https://${APP_DOMAIN}/up"
DOMAIN_ALIASES=""          # Các domain phụ cách nhau bằng dấu cách (vd: "mysite.vn www.mysite.com")
